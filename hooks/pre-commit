#!/bin/bash
# Pre-commit hook for Hachi
# Runs cargo fmt, cargo clippy (strict mode), and cargo doc (check docs)

set -e

echo "Running pre-commit checks..."

echo "  -> Running cargo fmt..."
cargo fmt --all

if ! git diff --quiet -- '*.rs'; then
    echo "cargo fmt changed Rust files. Review and stage those changes, then commit again."
    exit 1
fi

echo "  -> Running cargo clippy (strict mode)..."
if ! cargo clippy -q --message-format=short --all --all-targets --all-features -- -D warnings; then
    echo "Clippy failed with warnings or errors. Fix them before committing."
    exit 1
fi

echo "  -> Running cargo doc (check documentation)..."
if ! RUSTDOCFLAGS="-D warnings" cargo doc -q --no-deps --all-features; then
    echo "Documentation build failed with warnings or errors. Fix them before committing."
    exit 1
fi

echo "All pre-commit checks passed!"
exit 0
